# =============================================================================
# IWX Boardroom — Environment Configuration
# =============================================================================
# Copy this file to `.env` (already gitignored) and fill in real values.
# All services read these via docker compose env-substitution and through
# `appsettings.json` overrides (ASP.NET) or `os.environ` (Python).
#
# Quick start:
#   cp .env.example .env
#   ./start.ps1     (Windows PowerShell)   or   ./start.sh   (bash)
# =============================================================================

# -----------------------------------------------------------------------------
# Global / runtime
# -----------------------------------------------------------------------------
COMPOSE_PROJECT_NAME=iwx-boardroom
ASPNETCORE_ENVIRONMENT=Development
NODE_ENV=development
TZ=UTC

# Public-facing host (used by gateway, CORS, OAuth callbacks)
PUBLIC_HOST=http://localhost
PUBLIC_GATEWAY_PORT=8080

# -----------------------------------------------------------------------------
# Datastores
# -----------------------------------------------------------------------------
SQL_HOST=sqlserver
SQL_PORT=1433
SQL_SA_USER=sa
SQL_SA_PASSWORD=IwxStrong!Passw0rd
SQL_TRUST_CERT=True
SQL_ENCRYPT=False

MONGO_HOST=mongo
MONGO_PORT=27017
MONGO_USER=iwx
MONGO_PASS=iwx
MONGO_AUTH_SOURCE=admin

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# -----------------------------------------------------------------------------
# Messaging
# -----------------------------------------------------------------------------
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672
RABBITMQ_USER=iwx
RABBITMQ_PASS=iwx
RABBITMQ_VHOST=/

KAFKA_BOOTSTRAP=kafka:9092
KAFKA_HOST_PORT=9092

# -----------------------------------------------------------------------------
# Local LLM (Ollama)
# -----------------------------------------------------------------------------
OLLAMA_HOST=http://ollama:11434
OLLAMA_MODEL=llama3.2:3b
OLLAMA_EMBED_MODEL=nomic-embed-text

# -----------------------------------------------------------------------------
# Optional cloud LLM providers (leave blank to disable)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_KEY=
AZURE_OPENAI_DEPLOYMENT=
GOOGLE_AI_API_KEY=
GROQ_API_KEY=

# -----------------------------------------------------------------------------
# Auth / Security (rotate these in production!)
# -----------------------------------------------------------------------------
JWT_ISSUER=iwx-auth
JWT_AUDIENCE=iwx
JWT_SECRET=iwx-prod-rotate-this-secret-min-32-chars-long-please-1234
JWT_EXPIRES_MINUTES=120

CEO_BOOTSTRAP_USER=ceo
CEO_BOOTSTRAP_PASSWORD=ChangeMe!2026
CEO_BOOTSTRAP_EMAIL=ceo@iwx.local

# Spring Boot security engine
SECURITY_BLOCK_THRESHOLD=50

# -----------------------------------------------------------------------------
# Platform Connectors (fill the ones you actually use)
# -----------------------------------------------------------------------------

# Instagram (via Facebook Graph)
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ACCOUNT_ID=

# YouTube
YOUTUBE_API_KEY=
YOUTUBE_OAUTH_CLIENT_ID=
YOUTUBE_OAUTH_CLIENT_SECRET=
YOUTUBE_CHANNEL_ID=

# LinkedIn
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_ORGANIZATION_ID=

# Twitter / X
TWITTER_BEARER_TOKEN=
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=

# Facebook (Pages)
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_PAGE_ACCESS_TOKEN=
FACEBOOK_PAGE_ID=

# Reddit
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=
REDDIT_PASSWORD=
REDDIT_USER_AGENT=iwx-boardroom/1.0

# WhatsApp Cloud API
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_BUSINESS_ACCOUNT_ID=

# Email (SMTP / IMAP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@iwx.local
IMAP_HOST=
IMAP_PORT=993
IMAP_USER=
IMAP_PASS=

# Websites connector (web-scraping)
SCRAPER_USER_AGENT=Mozilla/5.0 (compatible; IWX-Boardroom/1.0)
SCRAPER_TIMEOUT_SECONDS=30
PLAYWRIGHT_BROWSER=chromium

# -----------------------------------------------------------------------------
# Vector store (Phase B — embeddings)
# -----------------------------------------------------------------------------
VECTOR_PROVIDER=chroma
CHROMA_HOST=chroma
CHROMA_PORT=8000
QDRANT_URL=
PINECONE_API_KEY=
PINECONE_INDEX=

# -----------------------------------------------------------------------------
# Observability (Phase J)
# -----------------------------------------------------------------------------
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_SERVICE_NAMESPACE=iwx
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# -----------------------------------------------------------------------------
# Frontend
# -----------------------------------------------------------------------------
DASHBOARD_PORT=4200
ADMIN_PANEL_PORT=4201
REALTIME_MONITOR_PORT=4202
ANALYTICS_DASHBOARD_PORT=4203
FRONTEND_API_BASE=http://localhost:8080
FRONTEND_HUB_URL=http://localhost:8080/hubs/boardroom
