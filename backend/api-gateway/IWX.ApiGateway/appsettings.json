{
  "Serilog": {
    "MinimumLevel": { "Default": "Information", "Override": { "Microsoft": "Warning" } }
  },
  "AllowedHosts": "*",
  "Kestrel": {
    "Endpoints": {
      "Http": { "Url": "http://0.0.0.0:8080" }
    }
  },
  "ReverseProxy": {
    "Routes": {
      "ceo-route":                  { "ClusterId": "ceo-cluster",                  "Match": { "Path": "/api/ceo/{**catch-all}" },                  "Transforms": [ { "PathRemovePrefix": "/api/ceo" } ] },
      "ceo-hub-route":              { "ClusterId": "ceo-cluster",                  "Match": { "Path": "/hubs/{**catch-all}" } },
      "orchestrator-route":         { "ClusterId": "orchestrator-cluster",         "Match": { "Path": "/api/ai/orchestrator/{**catch-all}" }, "Transforms": [ { "PathRemovePrefix": "/api/ai/orchestrator" } ] },

      "memory-route":               { "ClusterId": "memory-cluster",               "Match": { "Path": "/api/ai/memory/{**catch-all}" },            "Transforms": [ { "PathRemovePrefix": "/api/ai/memory" } ] },
      "llm-router-route":           { "ClusterId": "llm-router-cluster",           "Match": { "Path": "/api/ai/llm/{**catch-all}" },               "Transforms": [ { "PathRemovePrefix": "/api/ai/llm" } ] },
      "prompt-engine-route":        { "ClusterId": "prompt-engine-cluster",        "Match": { "Path": "/api/ai/prompts/{**catch-all}" },           "Transforms": [ { "PathRemovePrefix": "/api/ai/prompts" } ] },
      "vector-engine-route":        { "ClusterId": "vector-engine-cluster",        "Match": { "Path": "/api/ai/vectors/{**catch-all}" },           "Transforms": [ { "PathRemovePrefix": "/api/ai/vectors" } ] },
      "rag-engine-route":           { "ClusterId": "rag-engine-cluster",           "Match": { "Path": "/api/ai/rag/{**catch-all}" },               "Transforms": [ { "PathRemovePrefix": "/api/ai/rag" } ] },
      "reasoning-engine-route":     { "ClusterId": "reasoning-engine-cluster",     "Match": { "Path": "/api/ai/reasoning/{**catch-all}" },         "Transforms": [ { "PathRemovePrefix": "/api/ai/reasoning" } ] },

      "hr-route":                   { "ClusterId": "hr-cluster",                   "Match": { "Path": "/api/hr/{**catch-all}" },                   "Transforms": [ { "PathRemovePrefix": "/api/hr" } ] },
      "sales-route":                { "ClusterId": "sales-cluster",                "Match": { "Path": "/api/sales/{**catch-all}" },                "Transforms": [ { "PathRemovePrefix": "/api/sales" } ] },
      "finance-route":              { "ClusterId": "finance-cluster",              "Match": { "Path": "/api/finance/{**catch-all}" },              "Transforms": [ { "PathRemovePrefix": "/api/finance" } ] },
      "marketing-route":            { "ClusterId": "marketing-cluster",            "Match": { "Path": "/api/marketing/{**catch-all}" },            "Transforms": [ { "PathRemovePrefix": "/api/marketing" } ] },
      "operations-route":           { "ClusterId": "operations-cluster",           "Match": { "Path": "/api/operations/{**catch-all}" },           "Transforms": [ { "PathRemovePrefix": "/api/operations" } ] },
      "development-route":          { "ClusterId": "development-cluster",          "Match": { "Path": "/api/development/{**catch-all}" },          "Transforms": [ { "PathRemovePrefix": "/api/development" } ] },
      "research-route":             { "ClusterId": "research-cluster",             "Match": { "Path": "/api/research/{**catch-all}" },             "Transforms": [ { "PathRemovePrefix": "/api/research" } ] },
      "legal-route":                { "ClusterId": "legal-cluster",                "Match": { "Path": "/api/legal/{**catch-all}" },                "Transforms": [ { "PathRemovePrefix": "/api/legal" } ] },
      "social-media-route":         { "ClusterId": "social-media-cluster",         "Match": { "Path": "/api/social-media/{**catch-all}" },         "Transforms": [ { "PathRemovePrefix": "/api/social-media" } ] },
      "analytics-route":            { "ClusterId": "analytics-cluster",            "Match": { "Path": "/api/analytics/{**catch-all}" },            "Transforms": [ { "PathRemovePrefix": "/api/analytics" } ] },
      "customer-support-route":     { "ClusterId": "customer-support-cluster",     "Match": { "Path": "/api/customer-support/{**catch-all}" },     "Transforms": [ { "PathRemovePrefix": "/api/customer-support" } ] },
      "automation-route":           { "ClusterId": "automation-cluster",           "Match": { "Path": "/api/automation/{**catch-all}" },           "Transforms": [ { "PathRemovePrefix": "/api/automation" } ] },
      "platform-intelligence-route":{ "ClusterId": "platform-intelligence-cluster","Match": { "Path": "/api/platform-intelligence/{**catch-all}" },"Transforms": [ { "PathRemovePrefix": "/api/platform-intelligence" } ] },

      "instagram-connector-route": { "ClusterId": "instagram-connector-cluster", "Match": { "Path": "/api/connectors/instagram/{**catch-all}" }, "Transforms": [ { "PathRemovePrefix": "/api/connectors/instagram" } ] },
      "youtube-connector-route":   { "ClusterId": "youtube-connector-cluster",   "Match": { "Path": "/api/connectors/youtube/{**catch-all}" },   "Transforms": [ { "PathRemovePrefix": "/api/connectors/youtube" } ] },
      "linkedin-connector-route":  { "ClusterId": "linkedin-connector-cluster",  "Match": { "Path": "/api/connectors/linkedin/{**catch-all}" },  "Transforms": [ { "PathRemovePrefix": "/api/connectors/linkedin" } ] },
      "twitter-connector-route":   { "ClusterId": "twitter-connector-cluster",   "Match": { "Path": "/api/connectors/twitter/{**catch-all}" },   "Transforms": [ { "PathRemovePrefix": "/api/connectors/twitter" } ] },
      "facebook-connector-route":  { "ClusterId": "facebook-connector-cluster",  "Match": { "Path": "/api/connectors/facebook/{**catch-all}" },  "Transforms": [ { "PathRemovePrefix": "/api/connectors/facebook" } ] },
      "reddit-connector-route":    { "ClusterId": "reddit-connector-cluster",    "Match": { "Path": "/api/connectors/reddit/{**catch-all}" },    "Transforms": [ { "PathRemovePrefix": "/api/connectors/reddit" } ] },
      "whatsapp-connector-route":  { "ClusterId": "whatsapp-connector-cluster",  "Match": { "Path": "/api/connectors/whatsapp/{**catch-all}" },  "Transforms": [ { "PathRemovePrefix": "/api/connectors/whatsapp" } ] },
      "email-connector-route":     { "ClusterId": "email-connector-cluster",     "Match": { "Path": "/api/connectors/email/{**catch-all}" },     "Transforms": [ { "PathRemovePrefix": "/api/connectors/email" } ] },
      "websites-connector-route":  { "ClusterId": "websites-connector-cluster",  "Match": { "Path": "/api/connectors/websites/{**catch-all}" },  "Transforms": [ { "PathRemovePrefix": "/api/connectors/websites" } ] }
    },
    "Clusters": {
      "ceo-cluster":                  { "Destinations": { "d1": { "Address": "http://ceo-agent-service:8081/" } } },
      "orchestrator-cluster":         { "Destinations": { "d1": { "Address": "http://orchestrator-ai:8000/" } } },
      "memory-cluster":               { "Destinations": { "d1": { "Address": "http://memory-engine:8100/" } } },
      "llm-router-cluster":           { "Destinations": { "d1": { "Address": "http://llm-router:8101/" } } },
      "prompt-engine-cluster":        { "Destinations": { "d1": { "Address": "http://prompt-engine:8102/" } } },
      "vector-engine-cluster":        { "Destinations": { "d1": { "Address": "http://vector-engine:8103/" } } },
      "rag-engine-cluster":           { "Destinations": { "d1": { "Address": "http://rag-engine:8104/" } } },
      "reasoning-engine-cluster":     { "Destinations": { "d1": { "Address": "http://reasoning-engine:8105/" } } },
      "hr-cluster":                   { "Destinations": { "d1": { "Address": "http://hr-agent-service:8082/" } } },
      "sales-cluster":                { "Destinations": { "d1": { "Address": "http://sales-agent-service:8083/" } } },
      "finance-cluster":              { "Destinations": { "d1": { "Address": "http://finance-agent-service:8084/" } } },
      "marketing-cluster":            { "Destinations": { "d1": { "Address": "http://marketing-agent-service:8085/" } } },
      "operations-cluster":           { "Destinations": { "d1": { "Address": "http://operations-agent-service:8086/" } } },
      "development-cluster":          { "Destinations": { "d1": { "Address": "http://development-agent-service:8087/" } } },
      "research-cluster":             { "Destinations": { "d1": { "Address": "http://research-agent-service:8088/" } } },
      "legal-cluster":                { "Destinations": { "d1": { "Address": "http://legal-agent-service:8089/" } } },
      "social-media-cluster":         { "Destinations": { "d1": { "Address": "http://social-media-agent-service:8090/" } } },
      "analytics-cluster":            { "Destinations": { "d1": { "Address": "http://analytics-agent-service:8091/" } } },
      "customer-support-cluster":     { "Destinations": { "d1": { "Address": "http://customer-support-agent-service:8092/" } } },
      "automation-cluster":           { "Destinations": { "d1": { "Address": "http://automation-agent-service:8093/" } } },
      "platform-intelligence-cluster":{ "Destinations": { "d1": { "Address": "http://platform-intelligence-agent-service:8094/" } } },

      "instagram-connector-cluster": { "Destinations": { "d1": { "Address": "http://instagram-connector:8200/" } } },
      "youtube-connector-cluster":   { "Destinations": { "d1": { "Address": "http://youtube-connector:8201/" } } },
      "linkedin-connector-cluster":  { "Destinations": { "d1": { "Address": "http://linkedin-connector:8202/" } } },
      "twitter-connector-cluster":   { "Destinations": { "d1": { "Address": "http://twitter-connector:8203/" } } },
      "facebook-connector-cluster":  { "Destinations": { "d1": { "Address": "http://facebook-connector:8204/" } } },
      "reddit-connector-cluster":    { "Destinations": { "d1": { "Address": "http://reddit-connector:8205/" } } },
      "whatsapp-connector-cluster":  { "Destinations": { "d1": { "Address": "http://whatsapp-connector:8206/" } } },
      "email-connector-cluster":     { "Destinations": { "d1": { "Address": "http://email-connector:8207/" } } },
      "websites-connector-cluster":  { "Destinations": { "d1": { "Address": "http://websites-connector:8208/" } } }
    }
  }
}
